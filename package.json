{
  "$schema": "https://www.raycast.com/schemas/extension.json",
  "name": "leave-time-calculator",
  "title": "Leave Time Calculator",
  "description": "Calculate your leave time based on start time and break duration",
  "icon": "command-icon.png",
  "author": "harunon",
  "categories": ["Productivity"],
  "license": "MIT",
  "commands": [
    {
      "name": "calculate-leave-time",
      "title": "Calculate Leave Time",
      "description": "Enter start time and calculate when to leave work",
      "mode": "view",
      "preferences": [
        {
          "name": "defaultWorkHours",
          "type": "textfield",
          "required": false,
          "title": "Default Work Hours",
          "description": "Default work hours per day (e.g., 8, 9)",
          "default": "9"
        },
        {
          "name": "defaultBreakMinutes",
          "type": "textfield",
          "required": false,
          "title": "Default Break Minutes",
          "description": "Default break time in minutes (e.g., 60)",
          "default": "60"
        }
      ]
    }
  ],
  "dependencies": {
    "@raycast/api": "^1.104.1",
    "@raycast/utils": "^2.2.2",
    "react": "^19.2.3"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/node": "^20.17.6",
    "@types/react": "^19.2.7",
    "typescript": "^5.7.2"
  },
  "scripts": {
    "build": "ray build -e dist",
    "dev": "ray develop",
    "fix-lint": "ray lint --fix",
    "lint": "ray lint"
  }
}
